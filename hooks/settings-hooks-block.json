{
  "_comment": "Factory Droid example. Merge the 'hooks' object into ~/.factory/settings.json. The 'make install-factory-hooks' target does this idempotently.",
  "hooks": {
    "SessionStart": [
      { "hooks": [ { "type": "command", "command": "$AGENT_MENUBAR_HOOK", "timeout": 5 } ] }
    ],
    "SessionEnd": [
      { "hooks": [ { "type": "command", "command": "$AGENT_MENUBAR_HOOK", "timeout": 5 } ] }
    ],
    "Notification": [
      { "hooks": [ { "type": "command", "command": "$AGENT_MENUBAR_HOOK", "timeout": 5 } ] }
    ],
    "Stop": [
      { "hooks": [ { "type": "command", "command": "$AGENT_MENUBAR_HOOK", "timeout": 5 } ] }
    ],
    "UserPromptSubmit": [
      { "hooks": [ { "type": "command", "command": "$AGENT_MENUBAR_HOOK", "timeout": 5 } ] }
    ],
    "PreToolUse": [
      { "matcher": "AskUser", "hooks": [ { "type": "command", "command": "$AGENT_MENUBAR_HOOK", "timeout": 5 } ] }
    ],
    "PostToolUse": [
      { "matcher": "AskUser", "hooks": [ { "type": "command", "command": "$AGENT_MENUBAR_HOOK", "timeout": 5 } ] }
    ]
  }
}
